# Cloud function environment variables. Copy this file to .env locally if needed.
# Never commit real secrets.

# Optional: Doubao / Volcengine Ark caption generation
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-2-0-pro-260215

# Optional: authorized POI sync
XHS_POI_LIST_URL=
XHS_AUTH_ACCESS_TOKEN=

# Optional: AMap Web Service API
# Create a Web Service key in AMap console, then configure it as a cloud-function env var.
AMAP_WEB_SERVICE_KEY=
