{
  "appid": "touristappid",
  "compileType": "miniprogram",
  "cloudfunctionRoot": "cloudfunctions/",
  "libVersion": "latest",
  "miniprogramRoot": "./",
  "projectname": "chasing-light-journey",
  "setting": {
    "coverView": true,
    "es6": true,
    "postcss": true,
    "minified": true,
    "enhance": true,
    "compileWorklet": false,
    "uglifyFileName": false,
    "uploadWithSourceMap": true,
    "packNpmManually": false,
    "packNpmRelationList": [],
    "minifyWXSS": true,
    "minifyWXML": true,
    "localPlugins": false,
    "disableUseStrict": false,
    "useCompilerPlugins": false,
    "condition": false,
    "ignoreDevUnusedFiles": false,
    "swc": false,
    "disableSWC": true,
    "babelSetting": {
      "ignore": [],
      "disablePlugins": [],
      "outputPath": ""
    }
  },
  "condition": {},
  "simulatorPluginLibVersion": {},
  "packOptions": {
    "ignore": [
      {
        "type": "folder",
        "value": "docs"
      },
      {
        "type": "file",
        "value": "index.html"
      },
      {
        "type": "file",
        "value": "README.md"
      },
      {
        "type": "folder",
        "value": "pages/history"
      },
      {
        "type": "folder",
        "value": "pages/member"
      }
    ],
    "include": [
      {
        "type": "folder",
        "value": "pages/browse-history"
      },
      {
        "type": "folder",
        "value": "pages/settings"
      },
      {
        "type": "file",
        "value": "utils/browse-history.js"
      }
    ]
  },
  "editorSetting": {}
}
