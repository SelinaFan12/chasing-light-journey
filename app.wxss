page {
  min-height: 100%;
  background: #121217;
  color: #f4efe4;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Songti SC', 'Helvetica Neue', sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  line-height: 1.25;
  max-width: 100%;
  white-space: normal;
  word-break: break-word;
}

button::after {
  border: 0;
}

input,
textarea {
  color: #f4efe4;
}

.theme-light input,
.theme-light textarea {
  color: #27231d;
}

.page {
  width: 100%;
  min-height: 100vh;
  padding: 30rpx 28rpx 72rpx;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 76rpx 40rpx, rgba(216, 136, 61, 0.18), transparent 250rpx),
    radial-gradient(circle at 640rpx 120rpx, rgba(83, 119, 160, 0.18), transparent 300rpx),
    #121217;
}

.page.theme-light {
  background:
    radial-gradient(circle at 76rpx 40rpx, rgba(229, 180, 95, 0.18), transparent 250rpx),
    radial-gradient(circle at 640rpx 120rpx, rgba(93, 113, 140, 0.12), transparent 300rpx),
    #f7f2e8;
  color: #211f1a;
}

.eyebrow,
.mono {
  font-family: 'Menlo', 'SF Mono', 'JetBrains Mono', monospace;
  letter-spacing: 1rpx;
}

.eyebrow {
  color: #9c968c;
  font-size: 20rpx;
  line-height: 1.4;
  text-transform: uppercase;
}

.display-title {
  max-width: 100%;
  color: #f7f0df;
  font-family: 'Songti SC', 'STSong', serif;
  font-size: 66rpx;
  font-weight: 500;
  letter-spacing: 0;
  line-height: 1.08;
  overflow-wrap: break-word;
  word-break: break-word;
}

.display-title .accent,
.accent {
  color: #e5b45f;
}

.section-title {
  max-width: 100%;
  color: #f7f0df;
  font-family: 'Songti SC', 'STSong', serif;
  font-size: 42rpx;
  font-weight: 500;
  line-height: 1.08;
  overflow-wrap: break-word;
  word-break: break-word;
}

.sub-title {
  max-width: 100%;
  color: #f7f0df;
  font-size: 30rpx;
  font-weight: 650;
  line-height: 1.25;
  overflow-wrap: break-word;
  word-break: break-word;
}

.muted {
  color: #aaa399;
  font-size: 24rpx;
  line-height: 1.65;
}

.panel {
  background: rgba(25, 25, 31, 0.82);
  border: 1rpx solid rgba(244, 239, 228, 0.12);
}

.divider {
  height: 1rpx;
  background: rgba(244, 239, 228, 0.12);
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #e5b45f;
  box-shadow: 0 0 20rpx rgba(229, 180, 95, 0.7);
}

.chip-row {
  display: flex;
  gap: 14rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.chip {
  min-height: 62rpx;
  padding: 0 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  border: 1rpx solid rgba(244, 239, 228, 0.18);
  border-radius: 999rpx;
  color: #c8c0b4;
  font-size: 24rpx;
  font-weight: 600;
}

.chip.active {
  border-color: #e5b45f;
  background: rgba(229, 180, 95, 0.14);
  color: #f6d789;
}

.primary-button,
.secondary-button {
  min-height: 76rpx;
  padding: 16rpx 28rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.25;
  text-align: center;
  max-width: 100%;
}

.primary-button {
  background: #f2d28a;
  color: #141319;
}

.secondary-button {
  border: 1rpx solid rgba(244, 239, 228, 0.2);
  color: #f4efe4;
}

.section-head {
  margin: 44rpx 0 22rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid rgba(244, 239, 228, 0.12);
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
}

.section-head > view:first-child {
  min-width: 0;
}

.section-head button {
  flex: 0 0 auto;
}

.empty {
  padding: 34rpx;
  margin-top: 22rpx;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
}

.theme-light .eyebrow {
  color: #80776c;
}

.theme-light .display-title,
.theme-light .section-title,
.theme-light .sub-title {
  color: #27231d;
}

.theme-light .muted {
  color: #6f675e;
}

.theme-light .panel {
  background: rgba(255, 252, 245, 0.9);
  border-color: rgba(62, 48, 31, 0.14);
  box-shadow: 0 18rpx 48rpx rgba(73, 56, 34, 0.08);
}

.theme-light .divider,
.theme-light .section-head {
  border-color: rgba(62, 48, 31, 0.14);
}

.theme-light .chip {
  border-color: rgba(62, 48, 31, 0.18);
  background: rgba(255, 252, 245, 0.72);
  color: #554b40;
}

.theme-light .chip.active {
  border-color: #b9852f;
  background: rgba(229, 180, 95, 0.22);
  color: #7b5517;
}

.theme-light .primary-button {
  background: #27231d;
  color: #fffaf0;
}

.theme-light .secondary-button {
  border-color: rgba(62, 48, 31, 0.2);
  color: #27231d;
}
