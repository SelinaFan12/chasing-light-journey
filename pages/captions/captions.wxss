.captions-page {
  padding-top: 24rpx;
}

.top-panel {
  min-height: 380rpx;
  padding: 34rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.top-panel .display-title {
  margin: 20rpx 0 24rpx;
}

.generator {
  margin-top: 24rpx;
  padding: 26rpx;
  overflow: hidden;
}

.style-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.style-filter .chip {
  width: calc(50% - 9rpx);
  flex: 0 0 calc(50% - 9rpx);
  min-width: 0;
  min-height: 72rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: normal;
  overflow: visible;
}

.input-row {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 156rpx;
  gap: 14rpx;
  align-items: center;
}

.input-row input {
  min-height: 78rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(244, 239, 228, 0.15);
  color: #f7f0df;
  font-size: 26rpx;
  min-width: 0;
}

.input-row .primary-button {
  width: 100%;
  min-width: 0;
  padding-left: 18rpx;
  padding-right: 18rpx;
}

.placeholder {
  color: #6f6b66;
}

.custom-result {
  margin-top: 22rpx;
  padding: 24rpx;
  border-left: 2rpx solid #e5b45f;
  background: rgba(229, 180, 95, 0.08);
  color: #f7f0df;
  font-size: 29rpx;
  line-height: 1.55;
}

.custom-result .secondary-button {
  margin-top: 18rpx;
}

.caption-list {
  display: grid;
  gap: 18rpx;
}

.caption-card {
  padding: 26rpx;
}

.caption-no {
  color: #8f887d;
  font-size: 20rpx;
}

.caption-text {
  margin: 22rpx 0 24rpx;
  color: #f7f0df;
  font-family: 'Songti SC', serif;
  font-size: 36rpx;
  line-height: 1.35;
}

.theme-light .input-row input {
  border-color: rgba(62, 48, 31, 0.16);
  color: #27231d;
  background: rgba(255, 252, 245, 0.68);
}

.theme-light .placeholder {
  color: #9a9186;
}

.theme-light .custom-result {
  background: rgba(229, 180, 95, 0.14);
  color: #27231d;
}

.theme-light .caption-no {
  color: #80776c;
}

.theme-light .caption-text {
  color: #27231d;
}
