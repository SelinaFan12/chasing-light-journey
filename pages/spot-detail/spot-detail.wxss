.detail-page {
  padding-top: 24rpx;
}

.detail-hero {
  min-height: auto;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  position: relative;
  overflow: hidden;
}

.detail-hero::before {
  content: "";
  position: absolute;
  z-index: 0;
  right: -120rpx;
  top: -120rpx;
  width: 380rpx;
  height: 380rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(229, 180, 95, 0.25);
}

.hero-line {
  width: 100%;
  margin-bottom: 0;
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.hero-line .eyebrow {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score {
  flex: 0 0 auto;
  color: #f2d28a;
  font-size: 30rpx;
}

.detail-hero .display-title,
.detail-hero .hero-copy,
.detail-hero .hero-meta-row {
  position: relative;
  z-index: 1;
}

.detail-hero .display-title {
  margin-top: 34rpx;
  font-size: 56rpx;
  line-height: 1.14;
}

.hero-copy {
  margin-top: 22rpx;
  color: #c9c0b4;
  font-size: 27rpx;
  line-height: 1.65;
}

.hero-meta-row {
  margin-top: 34rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(244, 239, 228, 0.12);
  display: flex;
  align-items: flex-end;
  gap: 22rpx;
}

.meta-grid {
  flex: 1;
  min-width: 0;
  display: grid;
  grid-template-columns: minmax(96rpx, 0.7fr) minmax(0, 1.3fr);
  gap: 24rpx;
  color: #f7f0df;
  font-size: 25rpx;
  line-height: 1.45;
}

.meta-grid > view {
  min-width: 0;
}

.meta-label {
  margin-bottom: 8rpx;
  color: #8f887d;
  font-size: 19rpx;
}

.fav-button {
  flex: 0 0 auto;
  margin: 0;
  min-width: 172rpx;
  min-height: 68rpx;
  max-width: 220rpx;
  padding: 12rpx 26rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(244, 239, 228, 0.18);
  border-radius: 999rpx;
  color: #f4efe4;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
}

.fav-button.active {
  border-color: rgba(229, 180, 95, 0.56);
  color: #f2d28a;
}

.ai-example {
  height: 460rpx;
  margin-top: 22rpx;
  position: relative;
  overflow: hidden;
  background: #15151a;
}

.ai-example-img {
  width: 100%;
  height: 100%;
  display: block;
}

.ai-example-shade {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(18, 18, 23, 0.08), rgba(18, 18, 23, 0.1) 42%, rgba(18, 18, 23, 0.82));
}

.ai-example-top {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  top: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.ai-example-top .mono {
  color: rgba(247, 240, 223, 0.72);
  font-size: 18rpx;
}

.ai-example-copy {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 28rpx;
  color: #f7f0df;
  font-size: 25rpx;
  line-height: 1.55;
}

.location-list {
  display: grid;
  gap: 18rpx;
}

.location-card {
  padding: 28rpx 0;
  display: grid;
  grid-template-columns: 110rpx 1fr;
  gap: 22rpx;
}

.location-no {
  padding-left: 26rpx;
  color: #8f887d;
  font-size: 24rpx;
}

.location-body {
  padding-right: 26rpx;
  min-width: 0;
}

.tag {
  margin-bottom: 14rpx;
  color: #e5b45f;
  font-size: 20rpx;
}

.guide-points {
  margin: 22rpx 0 18rpx;
  display: grid;
  gap: 12rpx;
}

.address-row {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  display: grid;
  grid-template-columns: 72rpx 1fr;
  gap: 14rpx;
  border: 1rpx solid rgba(229, 180, 95, 0.2);
  background: rgba(229, 180, 95, 0.08);
  color: #d7cec1;
  font-size: 24rpx;
  line-height: 1.45;
}

.address-row text {
  color: #e5b45f;
  font-size: 19rpx;
}

.guide-points > view {
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(244, 239, 228, 0.1);
  background: rgba(244, 239, 228, 0.04);
  display: grid;
  grid-template-columns: 96rpx 1fr;
  gap: 16rpx;
  color: #d7cec1;
  font-size: 24rpx;
  line-height: 1.5;
}

.guide-points text {
  color: #e5b45f;
  font-size: 20rpx;
  font-weight: 800;
  white-space: nowrap;
}

.case-photo,
.case-empty,
.case-visual {
  height: 330rpx;
  margin: 24rpx 0;
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(244, 239, 228, 0.14);
}

.case-photo {
  background: #15151a;
}

.case-photo-img {
  width: 100%;
  height: 100%;
  display: block;
}

.case-photo-shade {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(18, 18, 23, 0.26), rgba(18, 18, 23, 0.06) 42%, rgba(18, 18, 23, 0.72));
  z-index: 2;
}

.case-photo-top {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  top: 16rpx;
  z-index: 3;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.case-label {
  position: absolute;
  left: 20rpx;
  top: 18rpx;
  z-index: 8;
  padding: 7rpx 10rpx;
  background: rgba(247, 240, 223, 0.72);
  color: rgba(18, 18, 23, 0.78);
  font-size: 19rpx;
  max-width: 54%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.case-photo .case-label {
  position: static;
  padding: 8rpx 12rpx;
  max-width: 58%;
  background: rgba(18, 18, 23, 0.58);
  color: #f7f0df;
}

.case-source {
  color: rgba(247, 240, 223, 0.82);
  font-size: 18rpx;
}

.case-credit {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 16rpx;
  z-index: 3;
  color: rgba(247, 240, 223, 0.78);
  font-size: 20rpx;
  line-height: 1.35;
}

.case-empty {
  padding: 34rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
  background: rgba(244, 239, 228, 0.04);
}

.case-empty-title {
  color: #f7f0df;
  font-size: 28rpx;
  font-weight: 800;
}

.case-visual-note {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 16rpx;
  z-index: 10;
  padding: 10rpx 14rpx;
  background: rgba(18, 18, 23, 0.58);
  color: #f7f0df;
  font-size: 20rpx;
  line-height: 1.35;
}

.rule-line {
  position: absolute;
  z-index: 7;
  background: rgba(247, 240, 223, 0.22);
}

.rule-line.vertical {
  top: 22rpx;
  bottom: 22rpx;
  width: 1rpx;
}

.rule-line.horizontal {
  left: 22rpx;
  right: 22rpx;
  height: 1rpx;
}

.rule-line.vertical.one {
  left: 33.33%;
}

.rule-line.vertical.two {
  left: 66.66%;
}

.rule-line.horizontal.one {
  top: 33.33%;
}

.rule-line.horizontal.two {
  top: 66.66%;
}

.case-frame {
  position: absolute;
  inset: 22rpx;
  border: 1rpx solid rgba(247, 240, 223, 0.26);
  z-index: 7;
}

.case-sun {
  position: absolute;
  right: 44rpx;
  top: 34rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: rgba(247, 240, 223, 0.9);
  box-shadow: 0 0 36rpx rgba(247, 240, 223, 0.5);
  z-index: 2;
}

.case-horizon {
  position: absolute;
  left: 26rpx;
  right: 26rpx;
  top: 118rpx;
  height: 1rpx;
  background: rgba(18, 18, 23, 0.34);
  z-index: 2;
}

.case-building {
  position: absolute;
  left: 56rpx;
  top: 76rpx;
  width: 158rpx;
  height: 112rpx;
  border: 2rpx solid rgba(18, 18, 23, 0.5);
  border-bottom: 0;
  z-index: 3;
}

.case-building::before,
.case-building::after {
  content: "";
  position: absolute;
  bottom: 0;
  background: rgba(18, 18, 23, 0.48);
}

.case-building::before {
  left: 22rpx;
  width: 30rpx;
  height: 72rpx;
}

.case-building::after {
  right: 22rpx;
  width: 42rpx;
  height: 54rpx;
}

.case-bridge {
  position: absolute;
  left: -20rpx;
  right: -20rpx;
  bottom: 92rpx;
  height: 18rpx;
  background: rgba(18, 18, 23, 0.45);
  transform: rotate(-7deg);
  transform-origin: left center;
  z-index: 4;
}

.case-water {
  position: absolute;
  left: -30rpx;
  right: -30rpx;
  bottom: 0;
  height: 92rpx;
  background: rgba(18, 18, 23, 0.22);
  transform: skewY(-5deg);
  z-index: 1;
}

.case-water::before,
.case-water::after {
  content: "";
  position: absolute;
  left: 54rpx;
  right: 70rpx;
  height: 2rpx;
  background: rgba(247, 240, 223, 0.42);
}

.case-water::before {
  top: 34rpx;
}

.case-water::after {
  top: 56rpx;
}

.case-tree {
  position: absolute;
  left: 26rpx;
  top: 44rpx;
  width: 88rpx;
  height: 126rpx;
  border-left: 8rpx solid rgba(18, 18, 23, 0.46);
  border-radius: 70% 0 0 0;
  z-index: 6;
}

.case-tree::before {
  content: "";
  position: absolute;
  left: -36rpx;
  top: -14rpx;
  width: 130rpx;
  height: 74rpx;
  border-radius: 50%;
  background: rgba(18, 18, 23, 0.18);
}

.case-path {
  position: absolute;
  left: 140rpx;
  right: 70rpx;
  bottom: -8rpx;
  height: 128rpx;
  background: rgba(247, 240, 223, 0.28);
  clip-path: polygon(36% 0, 62% 0, 100% 100%, 0 100%);
  z-index: 2;
}

.case-railing {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  bottom: 84rpx;
  height: 5rpx;
  background: rgba(18, 18, 23, 0.42);
  z-index: 5;
}

.case-railing::before {
  content: "";
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  top: 22rpx;
  height: 4rpx;
  background: rgba(18, 18, 23, 0.28);
}

.case-person {
  position: absolute;
  right: 106rpx;
  bottom: 90rpx;
  width: 42rpx;
  height: 94rpx;
  z-index: 9;
}

.person-head,
.person-body,
.person-arm,
.person-leg {
  position: absolute;
  background: rgba(18, 18, 23, 0.8);
}

.person-head {
  left: 11rpx;
  top: 0;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.person-body {
  left: 16rpx;
  top: 22rpx;
  width: 12rpx;
  height: 44rpx;
  border-radius: 999rpx 999rpx 8rpx 8rpx;
}

.person-arm {
  left: 6rpx;
  top: 34rpx;
  width: 32rpx;
  height: 6rpx;
  border-radius: 999rpx;
  transform: rotate(-18deg);
}

.person-leg {
  bottom: 0;
  width: 7rpx;
  height: 34rpx;
  border-radius: 999rpx;
  transform-origin: top center;
}

.person-leg.front {
  left: 17rpx;
  transform: rotate(12deg);
}

.person-leg.back {
  right: 15rpx;
  transform: rotate(-15deg);
}

.visual-wall .case-horizon,
.visual-wall .case-water,
.visual-wall .case-bridge,
.visual-wall .case-tree,
.visual-wall .case-path,
.visual-wall .case-railing {
  display: none;
}

.visual-wall .case-building {
  left: 0;
  right: 0;
  top: 64rpx;
  width: auto;
  height: 154rpx;
  border-left: 0;
  border-right: 0;
  background: rgba(18, 18, 23, 0.12);
}

.visual-city .case-building {
  left: 42rpx;
  top: 54rpx;
  width: 230rpx;
  height: 140rpx;
}

.visual-city .case-bridge {
  display: block;
}

.visual-city .case-tree,
.visual-city .case-path {
  display: none;
}

.visual-lake .case-building,
.visual-sea .case-building {
  top: 98rpx;
  width: 116rpx;
  height: 48rpx;
  opacity: 0.5;
}

.visual-lake .case-bridge,
.visual-sea .case-bridge {
  display: none;
}

.visual-steps .case-water,
.visual-steps .case-bridge {
  display: none;
}

.visual-steps .case-path {
  left: 58rpx;
  right: 58rpx;
  bottom: -24rpx;
  height: 190rpx;
  clip-path: polygon(20% 0, 80% 0, 100% 100%, 0 100%);
}

.visual-steps .case-path::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 34rpx;
  height: 5rpx;
  background: rgba(18, 18, 23, 0.22);
  box-shadow: 0 34rpx 0 rgba(18, 18, 23, 0.2), 0 68rpx 0 rgba(18, 18, 23, 0.18), 0 102rpx 0 rgba(18, 18, 23, 0.16);
}

.visual-mountain .case-water,
.visual-mountain .case-bridge,
.visual-mountain .case-railing {
  display: none;
}

.visual-mountain .case-horizon {
  top: 92rpx;
}

.visual-mountain .case-building {
  left: 24rpx;
  right: 24rpx;
  top: 86rpx;
  width: auto;
  height: 126rpx;
  border: 0;
  background: rgba(18, 18, 23, 0.28);
  clip-path: polygon(0 100%, 22% 36%, 38% 68%, 56% 22%, 76% 64%, 100% 18%, 100% 100%);
}

.visual-mountain .case-building::before,
.visual-mountain .case-building::after {
  display: none;
}

.visual-mountain .case-path {
  left: 92rpx;
  right: 78rpx;
  bottom: -18rpx;
  height: 142rpx;
  transform: rotate(-8deg);
}

.visual-night {
  background: linear-gradient(135deg, #20191d 0%, #52301e 52%, #b56b2c 100%) !important;
}

.visual-night .case-sun {
  width: 24rpx;
  height: 24rpx;
  background: #f2d28a;
}

.visual-night .case-building {
  left: 46rpx;
  top: 46rpx;
  width: 248rpx;
  height: 158rpx;
  background: rgba(18, 18, 23, 0.2);
}

.visual-night .case-building::before {
  box-shadow: 42rpx -18rpx 0 rgba(247, 240, 223, 0.45), 88rpx 10rpx 0 rgba(247, 240, 223, 0.38);
}

.visual-island .case-horizon,
.visual-sea .case-horizon {
  top: 106rpx;
}

.visual-island .case-building {
  top: 104rpx;
  width: 178rpx;
  height: 62rpx;
}

.pose-lower-right .case-person,
.pose-tree-right .case-person,
.pose-curve-end .case-person {
  right: 92rpx;
  bottom: 86rpx;
}

.pose-side-look .case-person,
.pose-walk-look .case-person,
.pose-slope-walk .case-person {
  right: 150rpx;
  bottom: 92rpx;
  transform: rotate(-3deg);
}

.pose-left-wall .case-person,
.pose-seated-left .case-person {
  left: 92rpx;
  right: auto;
}

.pose-seated-left .case-person {
  bottom: 82rpx;
  transform: rotate(90deg) scale(0.86);
}

.pose-bridge-45 .case-person,
.pose-half-right .case-person {
  right: 82rpx;
  bottom: 84rpx;
}

.pose-small-center .case-person,
.pose-night-small .case-person,
.pose-overlook .case-person {
  right: 50%;
  bottom: 108rpx;
  transform: translateX(50%) scale(0.72);
}

.pose-stairs-back .case-person,
.pose-steps-side .case-person {
  right: 128rpx;
  bottom: 92rpx;
  transform: scale(0.88);
}

.pose-boardwalk .case-person {
  right: 50%;
  bottom: 108rpx;
  transform: translateX(50%);
}

.pose-bridge-frame .case-person {
  left: 90rpx;
  right: auto;
  bottom: 104rpx;
}

.pose-backlight .case-person {
  right: 92rpx;
  bottom: 92rpx;
}

.pose-backlight .case-person::after {
  content: "";
  position: absolute;
  left: -14rpx;
  top: -12rpx;
  width: 70rpx;
  height: 104rpx;
  border-radius: 50%;
  box-shadow: 0 0 34rpx rgba(247, 240, 223, 0.72);
  z-index: -1;
}

.angle-grid {
  display: grid;
  gap: 10rpx;
  margin: 4rpx 0 18rpx;
}

.angle-grid > view {
  padding: 14rpx 0;
  border-top: 1rpx solid rgba(244, 239, 228, 0.1);
  color: #d7cec1;
  font-size: 24rpx;
  line-height: 1.45;
}

.angle-label {
  margin-bottom: 6rpx;
  color: #8f887d;
  font-size: 18rpx;
}

.tip {
  margin: 22rpx 0;
  padding: 22rpx;
  border-left: 2rpx solid #e5b45f;
  background: rgba(229, 180, 95, 0.08);
  color: #d9d1c4;
  font-size: 25rpx;
  line-height: 1.55;
}

.tip-label {
  margin-bottom: 8rpx;
  color: #e5b45f;
  font-size: 19rpx;
}

.shot-note {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(229, 180, 95, 0.2);
  color: #aaa399;
}

.primary-button {
  width: 100%;
}

.info-grid {
  margin-top: 22rpx;
  display: grid;
  gap: 18rpx;
}

.info-card {
  padding: 28rpx;
}

.info-card .sub-title {
  margin: 12rpx 0 18rpx;
}

.note-row {
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(244, 239, 228, 0.1);
  display: grid;
  grid-template-columns: 68rpx 1fr;
  gap: 18rpx;
  color: #d6cec2;
  font-size: 25rpx;
  line-height: 1.55;
}

.note-row text {
  color: #8f887d;
  font-size: 20rpx;
}

.theme-light .detail-hero::before {
  border-color: rgba(185, 133, 47, 0.24);
}

.theme-light .hero-copy {
  color: #5e554b;
}

.theme-light .hero-meta-row {
  border-color: rgba(62, 48, 31, 0.12);
}

.theme-light .meta-grid {
  color: #27231d;
}

.theme-light .meta-label,
.theme-light .location-no,
.theme-light .angle-label,
.theme-light .note-row text {
  color: #80776c;
}

.theme-light .fav-button {
  border-color: rgba(62, 48, 31, 0.2);
  color: #27231d;
}

.theme-light .fav-button.active {
  border-color: #b9852f;
  color: #7b5517;
  background: rgba(229, 180, 95, 0.16);
}

.theme-light .score,
.theme-light .tag,
.theme-light .tip-label {
  color: #9a671d;
}

.theme-light .angle-grid > view,
.theme-light .note-row,
.theme-light .shot-note {
  border-color: rgba(62, 48, 31, 0.12);
  color: #4f473d;
}

.theme-light .guide-points > view {
  border-color: rgba(62, 48, 31, 0.1);
  background: rgba(62, 48, 31, 0.035);
  color: #4f473d;
}

.theme-light .address-row {
  border-color: rgba(185, 133, 47, 0.22);
  background: rgba(229, 180, 95, 0.12);
  color: #4f473d;
}

.theme-light .tip {
  background: rgba(229, 180, 95, 0.14);
  color: #4f473d;
}

.theme-light .case-empty {
  background: rgba(62, 48, 31, 0.04);
}

.theme-light .case-empty-title {
  color: #27231d;
}
