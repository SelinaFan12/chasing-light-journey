.settings-page {
  padding-top: 24rpx;
}

.settings-hero {
  min-height: 360rpx;
  padding: 34rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 28rpx;
  position: relative;
  overflow: hidden;
}

.settings-hero::before {
  content: "";
  position: absolute;
  z-index: 0;
  right: -130rpx;
  top: -130rpx;
  width: 360rpx;
  height: 360rpx;
  border: 1rpx solid rgba(229, 180, 95, 0.24);
  border-radius: 50%;
}

.hero-copy {
  min-width: 0;
  position: relative;
  z-index: 1;
}

.settings-hero .display-title {
  margin: 14rpx 0 18rpx;
}

.hero-badge {
  width: 118rpx;
  height: 118rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 118rpx;
  position: relative;
  z-index: 1;
  border: 1rpx solid rgba(229, 180, 95, 0.42);
  border-radius: 50%;
  color: #e5b45f;
  font-size: 20rpx;
}

.settings-list {
  margin-top: 22rpx;
  display: grid;
  gap: 16rpx;
}

.setting-card {
  min-height: 156rpx;
  padding: 24rpx;
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) 120rpx;
  align-items: center;
  gap: 18rpx;
}

.setting-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(229, 180, 95, 0.28);
  border-radius: 50%;
  color: #e5b45f;
  font-size: 18rpx;
}

.setting-main {
  min-width: 0;
}

.setting-main .muted {
  margin-top: 8rpx;
}

.setting-action {
  width: 116rpx;
  min-height: 66rpx;
  padding: 12rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  justify-self: end;
  border: 1rpx solid rgba(229, 180, 95, 0.48);
  border-radius: 999rpx;
  color: #f2d28a;
  font-size: 24rpx;
  font-weight: 700;
}

.muted-action {
  border-color: rgba(244, 239, 228, 0.18);
  color: #c9c0b4;
}

.theme-light .hero-badge,
.theme-light .setting-icon {
  border-color: rgba(185, 133, 47, 0.38);
  color: #9a671d;
}

.theme-light .setting-action {
  border-color: #b9852f;
  color: #7b5517;
  background: rgba(229, 180, 95, 0.12);
}

.theme-light .muted-action {
  border-color: rgba(62, 48, 31, 0.16);
  color: #5f554a;
  background: transparent;
}
