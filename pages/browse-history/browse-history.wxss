.browse-history-page {
  padding-top: 24rpx;
}

.history-hero {
  min-height: 300rpx;
  padding: 32rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 22rpx;
}

.history-hero > view:first-child {
  min-width: 0;
}

.history-hero .display-title {
  margin: 14rpx 0 18rpx;
}

.clear-button {
  flex: 0 0 auto;
}

.history-list {
  margin-top: 22rpx;
  display: grid;
  gap: 16rpx;
}

.history-card {
  padding: 16rpx;
  display: grid;
  grid-template-columns: 168rpx minmax(0, 1fr);
  gap: 18rpx;
  overflow: hidden;
  border-radius: 16rpx;
}

.history-cover {
  height: 212rpx;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #c06739, #e8d7b9 52%, #4b6178);
}

.history-cover image {
  width: 100%;
  height: 100%;
  display: block;
}

.history-empty {
  position: absolute;
  left: 16rpx;
  top: 16rpx;
  color: rgba(18, 18, 23, 0.7);
  font-size: 18rpx;
}

.history-body {
  min-width: 0;
}

.history-meta,
.history-time {
  color: #e5b45f;
  font-size: 19rpx;
}

.history-body .sub-title {
  margin: 10rpx 0 12rpx;
}

.history-time {
  margin-top: 14rpx;
  color: #8f887d;
}

.theme-light .history-meta {
  color: #9a671d;
}

.theme-light .history-time {
  color: #80776c;
}

.theme-light .history-card {
  border-color: rgba(62, 48, 31, 0.08);
  background: #fffefa;
  box-shadow: 0 18rpx 42rpx rgba(62, 48, 31, 0.08);
}
