.home-page {
  padding-top: 24rpx;
  overflow-x: hidden;
}

.hero {
  min-height: 500rpx;
  padding: 34rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: "";
  position: absolute;
  z-index: 0;
  right: -160rpx;
  top: -90rpx;
  width: 430rpx;
  height: 430rpx;
  border: 1rpx solid rgba(244, 239, 228, 0.14);
  border-radius: 50%;
}

.hero::after {
  content: "";
  position: absolute;
  z-index: 0;
  right: 80rpx;
  top: 90rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #e5b45f;
  box-shadow: 0 0 50rpx rgba(229, 180, 95, 0.85);
}

.hero-meta {
  width: 100%;
  margin-bottom: auto;
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-width: 0;
}

.hero-meta .eyebrow {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero .display-title,
.hero .hero-copy,
.hero .hero-stats {
  position: relative;
  z-index: 1;
}

.hero .display-title {
  margin-top: 42rpx;
}

.live-row {
  flex: 0 0 auto;
  max-width: 48%;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #e5b45f;
  font-size: 19rpx;
  font-family: 'Menlo', monospace;
}

.live-row text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-copy {
  margin-top: 28rpx;
  max-width: 560rpx;
  color: #c7bfb2;
  font-size: 27rpx;
  line-height: 1.65;
}

.hero-stats {
  margin-top: 42rpx;
  padding-top: 26rpx;
  border-top: 1rpx solid rgba(244, 239, 228, 0.13);
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}

.stat-value {
  margin-bottom: 8rpx;
  color: #f7f0df;
  font-size: 34rpx;
}

.search-panel {
  margin-top: 24rpx;
  padding: 24rpx;
}

.mode-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.mode-button {
  min-height: 72rpx;
  padding: 14rpx 18rpx;
  border: 1rpx solid rgba(244, 239, 228, 0.14);
  color: #c7bfb2;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.25;
}

.mode-button.active {
  border-color: rgba(229, 180, 95, 0.58);
  background: rgba(229, 180, 95, 0.14);
  color: #f2d28a;
}

.location-line {
  margin-bottom: 18rpx;
  color: #8f887d;
  font-size: 19rpx;
}

.search-label {
  color: #8f887d;
  font-size: 20rpx;
}

.filter-label {
  margin: 18rpx 0 12rpx;
  color: #8f887d;
  font-size: 18rpx;
}

.search-row {
  margin: 16rpx 0 4rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 132rpx;
  gap: 12rpx;
  align-items: center;
}

.search-input {
  height: 86rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(244, 239, 228, 0.15);
  color: #f7f0df;
  font-size: 28rpx;
  min-width: 0;
}

.search-button {
  height: 86rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(229, 180, 95, 0.58);
  background: rgba(229, 180, 95, 0.16);
  color: #f2d28a;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1;
}

.amap-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.amap-text {
  min-width: 0;
  flex: 1;
  color: #8f887d;
  font-size: 18rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.amap-button {
  flex: 0 0 auto;
  min-width: 156rpx;
  min-height: 60rpx;
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(229, 180, 95, 0.48);
  color: #f2d28a;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.25;
}

.province-row {
  margin-bottom: 4rpx;
}

.theme-row {
  margin-bottom: 4rpx;
}

.placeholder {
  color: #6f6b66;
}

.quick-scroll {
  margin-top: 20rpx;
  width: 100%;
  overflow: hidden;
  white-space: nowrap;
}

.quick-track {
  display: flex;
  gap: 14rpx;
  width: max-content;
  min-width: 100%;
  padding-right: 2rpx;
}

.quick {
  width: 274rpx;
  flex: 0 0 274rpx;
  min-height: 128rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  text-align: left;
  min-width: 0;
  white-space: normal;
}

.quick text {
  color: #e5b45f;
  font-size: 18rpx;
}

.quick view {
  color: #f7f0df;
  font-size: 27rpx;
  font-weight: 700;
}

.spot-list {
  display: flex;
  gap: 18rpx;
  align-items: start;
}

.spot-column {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.load-more {
  width: 100%;
  min-height: 76rpx;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #f2d28a;
  font-size: 25rpx;
  font-weight: 700;
}

.spot-card {
  padding: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 16rpx;
  background: #18181d;
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.22);
}

.spot-media {
  height: 340rpx;
  margin: 8rpx 8rpx 0;
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(244, 239, 228, 0.16);
  border-radius: 14rpx;
  background: #15151a;
}

.spot-column .spot-card:nth-child(3n + 1) .spot-media {
  height: 400rpx;
}

.spot-column .spot-card:nth-child(4n + 2) .spot-media {
  height: 300rpx;
}

.spot-media::before {
  content: "";
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  top: 88rpx;
  height: 1rpx;
  background: rgba(18, 18, 23, 0.42);
}

.spot-media::after {
  content: "";
  position: absolute;
  left: -20rpx;
  right: -20rpx;
  bottom: -18rpx;
  height: 78rpx;
  background: rgba(18, 18, 23, 0.28);
  transform: skewY(-8deg);
}

.spot-media.has-photo::before,
.spot-media.has-photo::after {
  display: none;
}

.spot-cover-img {
  width: calc(100% - 12rpx);
  height: calc(100% - 12rpx);
  display: block;
  position: absolute;
  left: 6rpx;
  top: 6rpx;
  z-index: 1;
  border-radius: 10rpx;
}

.spot-main {
  min-width: 0;
  padding: 18rpx 18rpx 20rpx;
}

.spot-top {
  margin-bottom: 12rpx;
  display: block;
}

.spot-city {
  margin-bottom: 8rpx;
  color: #e5b45f;
  font-size: 18rpx;
}

.spot-name {
  color: #f7f0df;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.28;
  overflow-wrap: break-word;
  word-break: break-word;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.source-line {
  margin-top: 8rpx;
  color: #8f887d;
  font-size: 17rpx;
}

.spot-main > .muted {
  font-size: 21rpx;
  line-height: 1.45;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.tag-strip {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.mini-tag {
  max-width: 142rpx;
  padding: 6rpx 10rpx;
  overflow: hidden;
  border: 1rpx solid rgba(229, 180, 95, 0.22);
  border-radius: 999rpx;
  color: #d8c49a;
  font-size: 18rpx;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score {
  color: #f7f0df;
  text-align: left;
  font-size: 22rpx;
  font-weight: 800;
}

.score-box {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  text-align: left;
}

.distance {
  color: #e5b45f;
  font-size: 18rpx;
}

.spot-foot {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(244, 239, 228, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.palette {
  display: flex;
  gap: 10rpx;
}

.swatch {
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(244, 239, 228, 0.18);
}

.fav {
  min-width: 84rpx;
  min-height: 48rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(244, 239, 228, 0.17);
  border-radius: 999rpx;
  color: #c9c0b4;
  font-size: 21rpx;
  line-height: 1.2;
}

.fav.active {
  border-color: rgba(229, 180, 95, 0.55);
  color: #f2d28a;
}

.theme-light .hero::before {
  border-color: rgba(62, 48, 31, 0.12);
}

.theme-light .live-row,
.theme-light .spot-city,
.theme-light .distance,
.theme-light .quick text {
  color: #9a671d;
}

.theme-light .hero-copy {
  color: #5e554b;
}

.theme-light .hero-stats,
.theme-light .spot-foot {
  border-color: rgba(62, 48, 31, 0.12);
}

.theme-light .spot-card {
  border-color: rgba(62, 48, 31, 0.08);
  background: #fffefa;
  box-shadow: 0 18rpx 42rpx rgba(62, 48, 31, 0.08);
}

.theme-light .stat-value,
.theme-light .spot-name,
.theme-light .score,
.theme-light .quick view {
  color: #27231d;
}

.theme-light .search-label,
.theme-light .location-line,
.theme-light .source-line,
.theme-light .filter-label {
  color: #80776c;
}

.theme-light .mini-tag {
  border-color: rgba(185, 133, 47, 0.28);
  color: #7b5517;
  background: rgba(229, 180, 95, 0.12);
}

.theme-light .mode-button {
  border-color: rgba(62, 48, 31, 0.16);
  color: #5f554a;
}

.theme-light .mode-button.active {
  border-color: #b9852f;
  background: rgba(229, 180, 95, 0.22);
  color: #7b5517;
}

.theme-light .search-input {
  border-color: rgba(62, 48, 31, 0.16);
  color: #27231d;
  background: rgba(255, 252, 245, 0.68);
}

.theme-light .search-button {
  border-color: #b9852f;
  background: rgba(229, 180, 95, 0.18);
  color: #7b5517;
}

.theme-light .placeholder {
  color: #9a9186;
}

.theme-light .fav {
  border-color: rgba(62, 48, 31, 0.18);
  color: #5f554a;
}

.theme-light .fav.active {
  border-color: #b9852f;
  color: #7b5517;
  background: rgba(229, 180, 95, 0.16);
}
