<view class="page poses-page {{themeClass}}">
  <view class="top-panel panel">
    <view class="eyebrow">POSE ARCHIVE</view>
    <view class="display-title">让身体动作，也有<text class="accent">构图</text></view>
    <view class="muted">按场景筛选姿势，把“我该怎么站”变成可直接照做的拍摄动作。</view>
  </view>

  <view class="chip-row category-row">
    <button
      wx:for="{{categories}}"
      wx:key="*this"
      class="chip {{activeCategory === item ? 'active' : ''}}"
      data-category="{{item}}"
      bindtap="setCategory"
    >{{item}}</button>
  </view>

  <view class="pose-grid">
    <view wx:for="{{poseColumns}}" wx:key="*this" class="pose-column">
      <view wx:for="{{item}}" wx:for-item="pose" wx:key="id" class="pose-card panel">
        <view class="pose-media">
          <image
            class="pose-photo"
            src="{{pose.image}}"
            mode="widthFix"
            lazy-load="true"
          />
        </view>
        <view class="pose-body">
          <view class="pose-title">{{pose.title}}</view>
          <view class="muted">{{pose.desc}}</view>
          <view class="pose-foot">
            <text class="mono">{{pose.category}}</text>
            <text>{{pose.scene}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
