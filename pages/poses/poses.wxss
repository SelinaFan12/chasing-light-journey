.poses-page {
  padding-top: 24rpx;
}

.top-panel {
  padding: 34rpx;
  min-height: 390rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  position: relative;
  overflow: hidden;
}

.top-panel::after {
  content: "";
  position: absolute;
  z-index: 0;
  right: -120rpx;
  top: 40rpx;
  width: 330rpx;
  height: 330rpx;
  border: 1rpx solid rgba(244, 239, 228, 0.12);
  transform: rotate(28deg);
}

.top-panel .display-title {
  margin: 20rpx 0 24rpx;
}

.top-panel > view {
  position: relative;
  z-index: 1;
}

.category-row {
  margin: 24rpx 0 22rpx;
}

.pose-grid {
  display: flex;
  gap: 18rpx;
  align-items: start;
}

.pose-column {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.pose-card {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 16rpx;
  background: #18181d;
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.22);
}

.pose-media {
  position: relative;
  width: 100%;
  overflow: hidden;
  background: #0f0f14;
}

.pose-photo {
  width: 100%;
  height: auto;
  display: block;
}

.pose-body {
  min-height: 230rpx;
  padding: 18rpx;
  display: flex;
  flex-direction: column;
}

.pose-title {
  margin: 0 0 12rpx;
  color: #f7f0df;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.28;
}

.pose-body .muted {
  font-size: 21rpx;
  line-height: 1.45;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.pose-foot {
  margin-top: auto;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(244, 239, 228, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  color: #aaa399;
  font-size: 20rpx;
}

.pose-foot .mono {
  color: #e5b45f;
}

.theme-light .top-panel::after {
  border-color: rgba(62, 48, 31, 0.12);
}

.theme-light .pose-media {
  background: #eee6da;
}

.theme-light .pose-card {
  border-color: rgba(62, 48, 31, 0.08);
  background: #fffefa;
  box-shadow: 0 18rpx 42rpx rgba(62, 48, 31, 0.08);
}

.theme-light .pose-title {
  color: #27231d;
}

.theme-light .pose-foot {
  border-color: rgba(62, 48, 31, 0.12);
  color: #6f675e;
}

.theme-light .pose-foot .mono {
  color: #9a671d;
}
