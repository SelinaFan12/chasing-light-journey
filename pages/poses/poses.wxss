.poses-page {
  padding-top: 24rpx;
}

.top-panel {
  padding: 34rpx;
  min-height: 390rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  position: relative;
  overflow: hidden;
}

.top-panel::after {
  content: "";
  position: absolute;
  z-index: 0;
  right: -120rpx;
  top: 40rpx;
  width: 330rpx;
  height: 330rpx;
  border: 1rpx solid rgba(244, 239, 228, 0.12);
  transform: rotate(28deg);
}

.top-panel .display-title {
  margin: 20rpx 0 24rpx;
}

.top-panel > view {
  position: relative;
  z-index: 1;
}

.category-row {
  margin: 24rpx 0 22rpx;
}

.pose-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.pose-card {
  min-height: 650rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.pose-media {
  position: relative;
  width: 100%;
  height: 390rpx;
  overflow: hidden;
  background: #0f0f14;
}

.pose-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.pose-photo-shade {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(18, 18, 23, 0), rgba(18, 18, 23, 0.28));
}

.pose-no {
  position: absolute;
  left: 18rpx;
  bottom: 16rpx;
  color: #f6d789;
  font-size: 20rpx;
  text-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.35);
}

.pose-body {
  min-height: 260rpx;
  padding: 22rpx;
  display: flex;
  flex-direction: column;
}

.pose-title {
  margin: 0 0 14rpx;
  color: #f7f0df;
  font-family: 'Songti SC', serif;
  font-size: 34rpx;
  line-height: 1.12;
}

.pose-foot {
  margin-top: auto;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(244, 239, 228, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  color: #aaa399;
  font-size: 22rpx;
}

.pose-foot .mono {
  color: #e5b45f;
}

.theme-light .top-panel::after {
  border-color: rgba(62, 48, 31, 0.12);
}

.theme-light .pose-media {
  background: #eee6da;
}

.theme-light .pose-title {
  color: #27231d;
}

.theme-light .pose-foot {
  border-color: rgba(62, 48, 31, 0.12);
  color: #6f675e;
}

.theme-light .pose-foot .mono {
  color: #9a671d;
}
