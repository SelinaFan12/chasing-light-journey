.profile-page {
  padding-top: 24rpx;
}

.profile-hero {
  min-height: 360rpx;
  padding: 34rpx;
  display: grid;
  grid-template-columns: 124rpx minmax(0, 1fr);
  gap: 28rpx;
  align-items: end;
}

.avatar {
  width: 124rpx;
  height: 124rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(242, 210, 138, 0.6);
  border-radius: 50%;
  color: #f2d28a;
  font-size: 28rpx;
  font-weight: 700;
}

.avatar-image {
  display: block;
  object-fit: cover;
}

.profile-hero .display-title {
  margin: 14rpx 0 18rpx;
}

.login-button {
  margin-top: 22rpx;
}

.profile-editor {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 148rpx minmax(0, 1fr);
  gap: 14rpx;
  align-items: center;
}

.avatar-picker,
.nickname-input {
  min-height: 68rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(242, 210, 138, 0.46);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.04);
  color: #f7f0df;
  font-size: 24rpx;
}

.avatar-picker {
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #f2d28a;
  font-weight: 700;
  line-height: 1.2;
}

.nickname-input {
  width: 100%;
  padding: 0 22rpx;
}

.profile-page .placeholder {
  color: rgba(244, 239, 228, 0.48);
}

.record-grid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.record {
  padding: 22rpx;
}

.record-value {
  margin-bottom: 8rpx;
  color: #f7f0df;
  font-size: 34rpx;
}

.theme-panel {
  margin-top: 18rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.theme-switch {
  min-width: 172rpx;
  min-height: 68rpx;
  padding: 14rpx 22rpx;
  border: 1rpx solid rgba(229, 180, 95, 0.48);
  border-radius: 999rpx;
  color: #f2d28a;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.25;
}

.theme-switch.active {
  background: rgba(229, 180, 95, 0.16);
}

.favorite {
  margin-bottom: 16rpx;
  padding: 16rpx;
  display: grid;
  grid-template-columns: 156rpx minmax(0, 1fr);
  gap: 18rpx;
  overflow: hidden;
  border-radius: 16rpx;
}

.favorite-cover {
  width: 156rpx;
  height: 196rpx;
  overflow: hidden;
  background: rgba(244, 239, 228, 0.08);
}

.favorite-cover image {
  width: 100%;
  height: 100%;
  display: block;
}

.favorite-no {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8f887d;
  font-size: 22rpx;
}

.action-list {
  display: grid;
  gap: 16rpx;
}

.action {
  width: 100%;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  text-align: left;
}

.action > view:first-child {
  min-width: 0;
}

.share-action {
  border-color: rgba(229, 180, 95, 0.38);
}

.arrow {
  color: #e5b45f;
  font-size: 34rpx;
}

.theme-light .avatar {
  border-color: rgba(185, 133, 47, 0.6);
  color: #8a611f;
}

.theme-light .record-value,
.theme-light .favorite .sub-title,
.theme-light .action .sub-title {
  color: #27231d;
}

.theme-light .favorite-no {
  color: #80776c;
}

.theme-light .favorite {
  border-color: rgba(62, 48, 31, 0.08);
  background: #fffefa;
  box-shadow: 0 18rpx 42rpx rgba(62, 48, 31, 0.08);
}

.theme-light .theme-switch {
  border-color: #b9852f;
  color: #7b5517;
}

.theme-light .avatar-picker,
.theme-light .nickname-input {
  border-color: rgba(185, 133, 47, 0.42);
  background: #fffefa;
  color: #27231d;
}

.theme-light .avatar-picker {
  color: #7b5517;
}

.profile-page.theme-light .placeholder {
  color: rgba(111, 103, 94, 0.56);
}

.theme-light .theme-switch.active {
  background: rgba(229, 180, 95, 0.2);
}

.theme-light .arrow {
  color: #9a671d;
}
