<view class="page profile-page {{themeClass}}">
  <view class="profile-hero panel">
    <image wx:if="{{avatarUrl}}" class="avatar avatar-image" src="{{avatarUrl}}" mode="aspectFill"></image>
    <view wx:if="{{!avatarUrl}}" class="avatar">追光</view>
    <view>
      <view class="eyebrow">TRAVELER FILE</view>
      <view class="display-title">你的拍照<text class="accent">档案</text></view>
      <view wx:if="{{hasWechatLogin}}" class="muted">{{nickName}}，已进入本地档案；头像昵称可自行完善。</view>
      <view wx:if="{{!hasWechatLogin}}" class="muted">进入本地档案后，可以保存收藏和浏览记录；分享给好友不需要登录。</view>
      <button wx:if="{{!hasWechatLogin}}" class="primary-button login-button" bindtap="loginWithWechat">进入档案</button>
      <view wx:if="{{hasWechatLogin}}" class="profile-editor">
        <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          {{avatarUrl ? '更换头像' : '选择头像'}}
        </button>
        <input
          class="nickname-input"
          type="nickname"
          value="{{profileDraftName}}"
          placeholder="填写昵称"
          placeholder-class="placeholder"
          bindinput="onNicknameInput"
          bindblur="saveNickname"
        />
      </view>
    </view>
  </view>

  <view class="record-grid">
    <view wx:for="{{records}}" wx:key="label" class="record panel">
      <view class="mono record-value">{{item.value}}</view>
      <view class="muted">{{item.label}}</view>
    </view>
  </view>

  <view class="theme-panel panel">
    <view>
      <view class="eyebrow">APPEARANCE</view>
      <view class="sub-title">界面模式</view>
      <view class="muted">当前：{{themeText}}</view>
    </view>
    <button class="theme-switch {{isLightTheme ? 'active' : ''}}" bindtap="toggleThemeMode">
      {{isLightTheme ? '切回深色' : '切换白色'}}
    </button>
  </view>

  <view class="section-head">
    <view>
      <view class="eyebrow">I / FAVORITES</view>
      <view class="section-title">收藏机位</view>
    </view>
    <button wx:if="{{favoriteSpots.length}}" class="secondary-button" bindtap="clearFavorites">清空</button>
  </view>

  <view wx:for="{{favoriteSpots}}" wx:key="id" class="favorite panel" data-id="{{item.id}}" bindtap="openSpot">
    <view class="favorite-cover">
      <image wx:if="{{item.coverImage}}" src="{{item.coverImage}}" mode="aspectFill"></image>
      <view wx:else class="mono favorite-no">{{item.archiveNo}}</view>
    </view>
    <view>
      <view class="sub-title">{{item.name}}</view>
      <view class="muted">{{item.city}} · {{item.badge}}</view>
    </view>
  </view>

  <view wx:if="{{favoriteSpots.length === 0}}" class="empty panel">
    <view class="sub-title">还没有收藏机位</view>
    <view class="muted">在机位页点击收藏后，会在这里形成你的旅行摄影档案。</view>
  </view>

  <view class="section-head">
    <view>
      <view class="eyebrow">II / SETTINGS</view>
      <view class="section-title">更多功能</view>
    </view>
  </view>

  <view class="action-list">
    <button wx:for="{{actions}}" wx:key="title" class="action panel" data-type="{{item.type}}" bindtap="openAction">
      <view>
        <view class="sub-title">{{item.title}}</view>
        <view class="muted">{{item.desc}}</view>
      </view>
      <view class="arrow">→</view>
    </button>

    <button class="action panel share-action" open-type="share">
      <view>
        <view class="sub-title">分享给朋友</view>
        <view class="muted">发送追光地图小程序卡片，邀请朋友一起规划拍照路线。</view>
      </view>
      <view class="arrow">↗</view>
    </button>
  </view>
</view>
